#!/bin/zsh
# ------------------------------------------------------------------------------
# Zsh Functions
# ------------------------------------------------------------------------------
# This file serves as a portable alternative to Oh My Zsh's ZSH_CUSTOM directory.
#
# Key advantages over standard Oh My Zsh custom files:
# 1. Framework-agnostic: Functions remain available even if OMZ is disabled.
# 2. Portability: Simplifies symlinking a single file across different systems.
# 3. Explicit Control: Sourced manually in .zshrc to avoid "magic" autoloading.
# ------------------------------------------------------------------------------

# Vertically aligns trailing # or // comments per block with a 1-space gap.
# - Explicitly warns on usage/file errors.
# - Silent on success.
# - Blocks are defined by contiguous lines with trailing comments.
align_comments() {
  # Usage and existence guards with explicit messages
  if [[ -z "$1" ]]; then
    echo "Usage: align_comments <file_path>"
    return 1
  fi

  if [[ ! -f "$1" ]]; then
    echo "Error: File '$1' not found."
    return 1
  fi

  local f="$1"
  local tmp
  tmp=$(mktemp)

  # awk logic with output size validation
  if awk '
    function flush() {
      if (count > 0) {
        for (i=1; i<=count; i++) {
          # Match # or // but skip URL protocols (://)
          match(lines[i], /#|\/\//)
          c_idx = RSTART
          
          code = substr(lines[i], 1, c_idx - 1)
          comment = substr(lines[i], c_idx)
          
          sub(/[[:space:]]+$/, "", code)
          printf "%-*s %s\n", block_max, code, comment
        }
      }
      count = 0; block_max = 0
    }

    {
      # Look for comment symbols not preceded by a colon (avoids URLs)
      if (match($0, /[^:]#|[^:]\/\//)) {
        match($0, /#|\/\//)
        c_idx = RSTART
        code_part = substr($0, 1, c_idx - 1)

        # Only buffer if there is non-whitespace code before the symbol
        if (code_part ~ /[^[:space:]]/) {
          count++
          lines[count] = $0
          sub(/[[:space:]]+$/, "", code_part)
          if (length(code_part) > block_max) block_max = length(code_part)
          next
        }
      }
      # Standalone comments or blank lines trigger a block flush
      flush()
      print $0
    }
    END { flush() }
  ' "$f" > "$tmp" && [[ -s "$tmp" ]]; then
    mv "$tmp" "$f"
  else
    # Error message if the processing itself failed
    echo "Error: Alignment failed or produced empty output."
    rm -f "$tmp"
    return 1
  fi
}
